# Publication DB (runs on host port 5433)
PUBLICATION_DB_ADDRESS=postgresql://banzai:banzai_test@localhost:5433/banzai_test

# Site Deployment (local DB on port 5442 via docker-compose-site.yml)
DB_ADDRESS=postgresql://banzai@postgresql:5432/banzai_local
AWS_DB_ADDRESS=host=host.docker.internal port=5433 dbname=banzai_test user=banzai password=banzai_test

# Site config
SITE_ID=lsc
INSTRUMENT_TYPES=*
PUBLICATION_NAME=banzai_calibrations

# Paths (relative to tests/site_e2e working dir)
HOST_DATA_DIR=./data
HOST_PROCESSED_DIR=./data/output
PROCESSED_PATH=/data/processed

# API (for download worker) - FILL IN YOUR TOKEN
API_ROOT=https://archive-api.lco.global/
AUTH_TOKEN=

# Download worker
DOWNLOAD_WORKER_POLL_INTERVAL=1

# Messaging
FITS_BROKER=rabbitmq
FITS_BROKER_URL=amqp://rabbitmq:5672
FITS_EXCHANGE=fits_files
TASK_HOST=redis://redis:6379/0

# Celery
CELERY_TASK_QUEUE_NAME=e2e_task_queue
CELERY_LARGE_TASK_QUEUE_NAME=e2e_large_task_queue
BANZAI_WORKER_LOGLEVEL=debug
OMP_NUM_THREADS=2
OPENTSDB_PYTHON_METRICS_TEST_MODE=1
