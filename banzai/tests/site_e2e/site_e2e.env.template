# --- Parallel-stack isolation knobs (so e2e can run alongside `just site-up`) ---
# Container names get this prefix instead of "banzai-": e2e-banzai-postgresql, etc.
CONTAINER_PREFIX=e2e-banzai-
# Celery worker hostname suffix: banzai-worker-e2e instead of banzai-worker-local.
CELERY_HOSTNAME_SUFFIX=e2e
# Postgres host port for the e2e site stack (site-up uses 5442).
SITE_PG_HOST_PORT=5443
# Queue/exchange names are explicit so the test process and containers publish
# and consume from the same isolated e2e broker resources.
FITS_EXCHANGE=e2e_fits_files
PIPELINE_QUEUE_NAME=e2e_banzai_pipeline
CELERY_TASK_QUEUE_NAME=e2e_reduction_task_queue
CELERY_LARGE_TASK_QUEUE_NAME=e2e_large_reduction_task_queue
SUBFRAME_TASK_QUEUE_NAME=e2e_subframe_reduction_task_queue
STACK_QUEUE_NAME=e2e_banzai_stack_queue

# Publication DB (runs on host port 5433)
PUBLICATION_DB_ADDRESS=postgresql+psycopg://banzai:banzai_test@localhost:5433/banzai_test

# Site Deployment (local DB on port 5443 via docker-compose-site.yml — see SITE_PG_HOST_PORT above)
DB_ADDRESS=postgresql+psycopg://banzai@postgresql:5432/banzai_local
AWS_DB_ADDRESS=host=host.docker.internal port=5433 dbname=banzai_test user=banzai password=banzai_test

# Site config
SITE_ID=lsc
INSTRUMENT_TYPES=*
PUBLICATION_NAME=banzai_calibrations

# Host paths (must be absolute — mounted at the same path inside containers).
# Replace /absolute/path/to/banzai with your local checkout path.
HOST_RAW_DIR=/absolute/path/to/banzai/data/raw
HOST_CALS_DIR=/absolute/path/to/banzai/data/calibrations
HOST_REDUCED_DIR=/absolute/path/to/banzai/data/output

# API (for download worker) - FILL IN YOUR TOKEN
API_ROOT=https://archive-api.lco.global/
AUTH_TOKEN=

# Download worker
DOWNLOAD_WORKER_POLL_INTERVAL=1

# Message brokers
REDIS_URL=redis://host.docker.internal:6379/0
RABBITMQ_URL=amqp://host.docker.internal:5672

# Worker tuning
BANZAI_WORKER_LOGLEVEL=debug
OMP_NUM_THREADS=2
OPENTSDB_PYTHON_METRICS_TEST_MODE=1
